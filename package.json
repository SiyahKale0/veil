{
  "name": "veil",
  "version": "0.6.1",
  "private": true,
  "description": "Prove something true about you without revealing who you are.",
  "type": "module",
  "license": "Apache-2.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "demo": "tsx --conditions=development packages/demo/src/demo.ts",
    "demo:vault": "tsx --conditions=development packages/demo/src/vault-demo.ts",
    "demo:consent": "tsx --conditions=development packages/demo/src/consent-demo.ts",
    "demo:bbs": "tsx --conditions=development packages/demo/src/bbs-demo.ts",
    "demo:zk": "tsx --conditions=development packages/demo/src/zk-demo.ts",
    "test": "vitest run",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "bench:browser": "vitest run --config vitest.bench.config.ts --reporter=verbose",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "build": "tsc -b",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/node": "22.19.19",
    "@vitest/browser": "4.1.7",
    "@vitest/browser-playwright": "4.1.7",
    "fast-check": "4.8.0",
    "playwright": "1.60.0",
    "tsx": "4.22.3",
    "typescript": "5.9.3",
    "vitest": "4.1.7"
  }
}
