{
  "name": "veil",
  "version": "0.1.0",
  "private": true,
  "description": "Prove something true about you without revealing who you are.",
  "type": "module",
  "license": "Apache-2.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "demo": "tsx packages/demo/src/demo.ts",
    "demo:vault": "tsx packages/demo/src/vault-demo.ts",
    "demo:consent": "tsx packages/demo/src/consent-demo.ts",
    "demo:bbs": "tsx packages/demo/src/bbs-demo.ts",
    "demo:zk": "tsx packages/demo/src/zk-demo.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "build": "tsc -b",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/libsodium-wrappers": "0.7.14",
    "@types/node": "22.19.19",
    "tsx": "4.22.3",
    "typescript": "5.9.3",
    "vitest": "4.1.7"
  }
}
